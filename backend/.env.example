# ─────────────────────────────────────────────────────────────
# AI Logistics Operations Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file. It is listed in .gitignore.
# ─────────────────────────────────────────────────────────────

# Set to True during development to use mock API responses.
# Set to False in production to enable real API calls.
MOCK_MODE=True

# Google AI Studio — Gemini 1.5 Flash
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 17TRACK Logistics API
# https://www.17track.net/en/apiDoc
SEVENTEENTRACK_TOKEN=your_17track_token_here

# OpenWeatherMap API
# https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Resend Email API
# https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# The email address to receive high-risk alerts.
# For Day 1 testing, use your Resend-verified account email
# to bypass domain verification requirements.
ALERT_RECIPIENT_EMAIL=your_email@example.com

# GCP — Only needed for local development with a service account key.
# On Cloud Run, Application Default Credentials (ADC) are used automatically.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
INTERNAL_SECRET=your-secret-here
